{
  "name": "mcp-dummy-project-setup",
  "version": "1.0.0",
  "description": "A simple MCP server setup",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "chatbot": "tsx src/chatbot.ts",
    "api": "tsx src/api.ts",
    "dev:api": "tsx src/mcp-api-bridge.ts",
    "web:dev": "npm run dev --prefix web-app",
    "dev:all": "concurrently \"npm run api\" \"npm run dev:api\" \"npm run web:dev\" --names \"API,BRIDGE,WEB\" --prefix name"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "openai": "^6.34.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "latest",
    "concurrently": "^8.2.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
